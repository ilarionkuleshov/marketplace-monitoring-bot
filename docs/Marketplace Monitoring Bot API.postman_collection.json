{
    "info": {
        "name": "Marketplace Monitoring Bot API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Read User",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{api_url}}/user/",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": "/user/",
                    "query": [
                        {
                            "key": "telegram_id",
                            "value": null,
                            "disabled": true
                        }
                    ]
                }
            }
        },
        {
            "name": "Create User",
            "request": {
                "method": "POST",
                "url": {
                    "raw": "{{api_url}}/user/",
                    "host": [
                        "{{api_url}}"
                    ],
                    "path": "/user/"
                },
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"telegram_id\": 123456,\n    \"name\": \"example_name\",\n    \"language\": \"en\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                }
            }
        }
    ],
    "auth": {
        "type": "apikey",
        "apikey": [
            {
                "key": "value",
                "value": "{{x_api_key}}",
                "type": "string"
            },
            {
                "key": "key",
                "value": "x-api-key",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "api_url",
            "value": "",
            "type": "string"
        },
        {
            "key": "x_api_key",
            "value": "",
            "type": "string"
        }
    ]
}